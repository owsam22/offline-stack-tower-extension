{
    "manifest_version": 3,
    "name": "Offline Focus Tower",
    "version": "1.0",
    "description": "A simple stacking game for when you're offline",
    "icons": {
        "16": "icon16.png",
        "48": "icon48.png",
        "128": "icon128.png"
    },
    "permissions": [
        "offline","tabs"
    ],
    "background": {
        "service_worker": "background.js"
    }
}